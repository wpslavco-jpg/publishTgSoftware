# LLM API (ChadGPT / OpenAI-compatible)
APP_LLM_BASE_URL=https://ask.chadgpt.ru/api/v1
APP_LLM_API_KEY=your-api-key-here
APP_LLM_MODEL=gpt-5-mini

# Database (used by docker-compose)
APP_DATASOURCE_URL=jdbc:postgresql://localhost:5432/app_db
APP_DATASOURCE_USERNAME=user
APP_DATASOURCE_PASSWORD=password

# Admin UI origin for CORS
APP_ADMIN_ORIGIN=http://localhost:5173

# Telegram Bot
APP_TELEGRAM_BOT_TOKEN=
APP_TELEGRAM_CHAT_ID=
APP_TELEGRAM_BOT_USERNAME=
# Личный chat ID с ботом для черновиков (напишите боту /start, затем «Найти chat ID» в админке)
APP_TELEGRAM_DRAFT_CHAT_ID=

# Telegram User Client (native scheduled messages — requires admin account session)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_USER_SESSION=

# Backend → user client
APP_TELEGRAM_USER_CLIENT_URL=http://localhost:8090
APP_TELEGRAM_USER_CLIENT_ENABLED=true

# Telegram Bot API proxy (required if api.telegram.org is blocked)
# APP_TELEGRAM_PROXY_HOST=127.0.0.1
# APP_TELEGRAM_PROXY_PORT=7890
