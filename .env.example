# =============================================================================
# Geek Parser — переменные окружения
# Скопируйте: cp .env.example .env
# =============================================================================

# --- LLM / ChadGPT (OpenAI-compatible API) ---
# Получить ключ: https://ask.chadgpt.ru
APP_LLM_BASE_URL=https://ask.chadgpt.ru/api/v1
APP_LLM_API_KEY=your-chadgpt-api-key-here
APP_LLM_MODEL=gpt-5-mini
# APP_LLM_CONNECT_TIMEOUT=5s
# APP_LLM_READ_TIMEOUT=60s

# --- PostgreSQL ---
APP_DATASOURCE_URL=jdbc:postgresql://localhost:5432/app_db
APP_DATASOURCE_USERNAME=user
APP_DATASOURCE_PASSWORD=password

# --- Admin UI (CORS) ---
APP_ADMIN_ORIGIN=http://localhost:5173

# --- Хранилище статей (markdown) ---
APP_RAW_ARTICLES_DIR=../storage/articles/raw

# --- Планировщик ---
APP_INGESTION_CRON=0 0 */2 * * *
APP_PUBLICATION_CRON=0/30 * * * * *

# --- Telegram Bot ---
APP_TELEGRAM_BOT_TOKEN=
APP_TELEGRAM_CHAT_ID=
APP_TELEGRAM_BOT_USERNAME=
# Личный chat ID с ботом для черновиков (напишите боту /start, затем «Найти chat ID» в админке)
APP_TELEGRAM_DRAFT_CHAT_ID=

# --- Telegram User Client (native «Отложенная отправка», опционально) ---
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_USER_SESSION=
APP_TELEGRAM_USER_CLIENT_URL=http://localhost:8090
APP_TELEGRAM_USER_CLIENT_ENABLED=false

# --- Telegram Bot API proxy (если api.telegram.org заблокирован) ---
# APP_TELEGRAM_API_BASE_URL=https://api.telegram.org
# APP_TELEGRAM_PROXY_HOST=127.0.0.1
# APP_TELEGRAM_PROXY_PORT=7890
